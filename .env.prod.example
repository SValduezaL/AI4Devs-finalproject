# =============================================================================
# VARIABLES DE ENTORNO — PRODUCCIÓN (plantilla)
# =============================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como .env.prod en el servidor Lightsail (~/adresles-prod/.env.prod)
#   2. Rellenar los valores reales (NO commitear .env.prod al repositorio)
#   3. Este archivo (.env.prod.example) SÍ se commitea — no contiene secrets reales
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL (Supabase)
# -----------------------------------------------------------------------------
# URL con connection pooler (para la API NestJS con Prisma)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa (para migraciones Prisma)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Redis (lo provee el contenedor, no cambiar salvo que uses Redis externo)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# AWS — DynamoDB producción
# -----------------------------------------------------------------------------
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
DYNAMODB_TABLE_NAME="adresles-messages-prod"
# DYNAMODB_ENDPOINT — NO definir en producción (usa AWS real, no local)

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""

# -----------------------------------------------------------------------------
# URL de la API — usada por web-admin en Vercel para llamar al backend
# NO es la URL del propio frontend (simulator.adresles.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="https://backend.adresles.com"
