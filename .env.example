# =============================================================================
# Adresles monorepo — variables de entorno (desarrollo local)
# Copiar este archivo a .env en la raíz y rellenar los valores.
# API, Worker, Prisma y web-admin leen desde el .env de la raíz.
# =============================================================================

# Database (Prisma, API, Worker)
DB_USER="my_project_user"
DB_PASSWORD="my_password"
## El Pooler (Para la lógica de tu API)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/postgres?sslmode=disable"
## La Directa (Para comandos de Prisma: migrate, push, etc.)
DIRECT_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/postgres?sslmode=disable"

# Redis (BullMQ - API, Worker)
REDIS_URL="redis://localhost:6379"

# AWS / DynamoDB Local (API, Worker)
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="local"
AWS_SECRET_ACCESS_KEY="local"
DYNAMODB_TABLE_NAME="adresles-messages"
DYNAMODB_ENDPOINT="http://localhost:8000"

# OpenAI (Worker)
OPENAI_API_KEY=""

# Google Maps (Worker - validación de direcciones)
GOOGLE_MAPS_API_KEY=""

# Web Admin (Next.js - URL de la API)
NEXT_PUBLIC_API_URL="http://localhost:3000"
