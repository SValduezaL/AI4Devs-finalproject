{
  "name": "adresles",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @adresles/prisma-db run generate",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:seed": "node -r dotenv/config -r ts-node/register packages/prisma-db/seed.ts dotenv_config_path=.env",
    "db:studio": "pnpm --filter api exec prisma studio",
    "db:migrate:deploy": "pnpm --filter api exec prisma migrate deploy",
    "dynamo:setup": "ts-node --require dotenv/config infrastructure/scripts/setup-dynamodb.ts dotenv_config_path=.env",
    "dynamo:validate:dev": "node -r ts-node/register infrastructure/scripts/validate-dynamodb-aws.ts .env.dev",
    "dynamo:validate:prod": "node -r ts-node/register infrastructure/scripts/validate-dynamodb-aws.ts .env.prod"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/lib-dynamodb": "^3.995.0",
    "@types/node": "^20.0.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.0",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
